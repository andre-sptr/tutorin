# Copy this file to .env and fill the real values.
# Never commit .env or service account JSON files.

# Public app URLs
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI chat and AI content text generator
SUMOPOD_API_KEY=your_sumopod_api_key
AI_CONTENT_MODEL=claude-haiku-4-5

# AI featured image generator: Google Cloud Vertex AI
AI_IMAGE_ENABLED=true
AI_IMAGE_PROVIDER=vertex
AI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_API_KEY=your_vertex_ai_express_api_key
AI_IMAGE_ASPECT_RATIO=16:9
AI_IMAGE_MIME_TYPE=image/png
AI_IMAGE_TIMEOUT_MS=20000

# This uses Vertex AI Express mode through @google/genai:
# new GoogleGenAI({ vertexai: true, apiKey: process.env.GEMINI_API_KEY })

# Admin panel /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ADMIN_SESSION_SECRET=change_this_to_a_long_random_secret

# Strapi write token for creating draft tutorials/categories/tags and uploading media
STRAPI_WRITE_TOKEN=your_strapi_write_api_token

# Secret for /api/cron/generate-content
CRON_SECRET=change_this_to_a_long_random_secret
